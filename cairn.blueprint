# Firth architecture blueprint.
# Firth is a concatenative language elaborated through Lean 4 and compiled to
# a Forth-class VM. The repo is spec-phase: no source code exists yet, so
# module paths under src/, spec/, stdlib/ and specs/ are declarations of
# intent, reconciled once implementation begins. See files/firth-prd.md and
# files/firth-kernel-spec-draft.md for the requirements these modules encode.
# Grammar reference: https://github.com/cairn-framework/cairn/blob/HEAD/docs/blueprint.md

System Firth "Concatenative language elaborated through Lean 4 and compiled to a Forth-class VM" id "firth" {
    todos "./meta/todos"
    decisions "./meta/decisions"
    research "./meta/research"
    sources "./meta/sources"

    Container Language "Language and specification layer: kernel calculus, surface syntax, type system" id "firth.language" {

        Module Kernel "Kernel calculus: combinator set, typing rules, small-step operational semantics, cost semantics" id "firth.language.kernel" {
            path "files"
            path "spec/kernel"
            path "src/interpreter/Firth/KernelMetatheory.lean"
        }

        Module Surface "Surface syntax: point-free Forth-flavoured syntax, named locals as sugar, vocabulary layering, naming grammar" id "firth.language.surface" {
            path "spec/surface"
        }

        Module Types "Type system: stack effects with row polymorphism, linearity, refinements, quotation typing" id "firth.language.types" {
            path "spec/types"
        }
    }

    Container Toolchain "Elaboration, compilation, and verification toolchain" id "firth.toolchain" {

        Module Elaborator "Elaborator: surface syntax into kernel terms, embedded in Lean 4; checks types, linearity, and proof obligations" id "firth.toolchain.elaborator" {
            path "src/elaborator"
            path "lean-toolchain"
            path "lakefile.toml"
            path "lake-manifest.json"
        }

        Module Interpreter "Reference interpreter: deliberately simple executable semantics in Lean, the behavioural oracle for program meaning" id "firth.toolchain.interpreter" {
            path "src/interpreter"
        }

        Module Compiler "Compiler: kernel calculus into the Forth-class target" id "firth.toolchain.compiler" {
            path "src/compiler"
        }

        Module DiffHarness "Differential test harness: fuzzed program generation checking compiler-versus-interpreter agreement" id "firth.toolchain.diffharness" {
            path "src/diffharness"
        }

        Module Smt "SMT integration for automatic refinement discharge" id "firth.toolchain.smt" {
            path "src/smt"
        }

        Module AgentInterface "Agent interface: structured machine-parseable diagnostics, typed holes, signature search over the dictionary" id "firth.toolchain.agent" {
            path "src/agent"
        }
    }

    Container Runtime "Execution runtime: VM, image model, live patching" id "firth.runtime" {

        Module Vm "Minimal permissively-licensed VM implementing the Forth-class target semantics" id "firth.runtime.vm" {
            path "src/runtime/vm"
        }

        Module Image "Image model with word-level hot redefinition" id "firth.runtime.image" {
            path "src/runtime/image"
        }

        Module Patch "Verified-patch protocol: the mechanism by which a re-checked word replaces its predecessor in a live image" id "firth.runtime.patch" {
            path "src/runtime/patch"
        }
    }

    Container Ecosystem "Ecosystem surface: standard library, tooling, reimplementable specifications" id "firth.ecosystem" {

        Module Stdlib "Standard library written in Firth itself, specified and progressively verified" id "firth.ecosystem.stdlib" {
            path "stdlib"
        }

        Module Lsp "Language server and editor support for practical authoring" id "firth.ecosystem.lsp" {
            path "src/lsp"
        }

        Module Specs "Specification documents for the kernel calculus and target VM, written to be reimplementable by third parties" id "firth.ecosystem.specs" {
            path "specs"
        }
    }

    Container Governance "Development governance and loop machinery" id "firth.governance" {

        Module Loop "Autonomous dev-loop command, procedures, and deterministic unit selector" id "firth.governance.loop" {
            path ".claude"
            path "tools/loop"
            path "docs"
        }
    }
}

# Edges are implementation prerequisites, not narrative data flow:
# kernel semantics first, then interpreter and target contract, then compiler
# and elaborator components, with differential, patch, and ecosystem surfaces
# depending on the checked artefacts described in files/firth-prd.md.

# Edges use cairn's depends-on semantics: A -> B means A requires B.
firth.language.surface -> firth.language.kernel "surface syntax targets the kernel"
firth.language.types -> firth.language.kernel "type rules target the kernel"
firth.toolchain.elaborator -> firth.language.surface "elaborator consumes surface syntax"
firth.toolchain.elaborator -> firth.language.types "elaborator consumes type rules"
firth.toolchain.elaborator -> firth.language.kernel "elaborator produces checked kernel terms"
firth.toolchain.elaborator -> firth.toolchain.smt "elaborator discharges refinements via SMT"
firth.toolchain.smt -> firth.language.kernel "refinement discharge targets kernel stack semantics"
firth.toolchain.compiler -> firth.language.kernel "compiler consumes kernel terms"
firth.toolchain.compiler -> firth.runtime.vm "compiler targets the VM instruction contract"
firth.toolchain.interpreter -> firth.language.kernel "interpreter executes kernel terms"
firth.runtime.vm -> firth.toolchain.interpreter "VM target is validated against interpreter semantics"
firth.toolchain.diffharness -> firth.toolchain.compiler "harness checks compiler output"
firth.toolchain.diffharness -> firth.toolchain.interpreter "harness checks interpreter output"
firth.toolchain.agent -> firth.toolchain.elaborator "agent consumes elaborator diagnostics"
firth.runtime.image -> firth.runtime.vm "image model runs on the VM"
firth.runtime.patch -> firth.toolchain.elaborator "patches re-elaborate replacement words"
firth.runtime.patch -> firth.runtime.vm "patches are admitted to the VM"
firth.runtime.patch -> firth.runtime.image "patches update the live image"
firth.ecosystem.stdlib -> firth.toolchain.elaborator "stdlib words are elaborated"
firth.ecosystem.lsp -> firth.toolchain.elaborator "LSP surfaces elaborator diagnostics"
firth.ecosystem.lsp -> firth.toolchain.agent "LSP consumes structured agent feedback"
firth.ecosystem.specs -> firth.language.kernel "specs document the kernel"
firth.ecosystem.specs -> firth.runtime.vm "specs document the VM"
